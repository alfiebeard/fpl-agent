# FPL Agent – copy to .env and fill in your keys.
# You need at least one of the following depending on config.yaml LLM providers.

# Gemini AI API key (for default Gemini models; subject to rate limits)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API key (for models via OpenRouter, e.g. Grok, GPT, Qwen)
OPENROUTER_API_KEY=your_openrouter_api_key_here
