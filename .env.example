# FPL Optimizer Environment Variables
# Copy this file to .env and add your API keys

# === RECOMMENDED: Google Gemini (Best Free Tier) ===
# Get your free API key at: https://aistudio.google.com/app/apikey
# Free tier: 15 requests/minute, 1M tokens/day
GEMINI_API_KEY=your_gemini_api_key_here

# === Alternative LLM Providers ===
# OpenAI (Limited free credits)
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude (Mostly paid)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === Optional FPL API Settings ===
# FPL_EMAIL=your_fpl_email@example.com
# FPL_PASSWORD=your_fpl_password
# FPL_TEAM_ID=your_team_id
# FPL_LEAGUE_ID=your_league_id